datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum SubStatus {
  TRIAL
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

model Shop {
  id        String   @id @default(uuid())
  name      String
  trn       String?
  address   String?
  email     String?
  phone     String?
  slogan    String?
  logoUrl   String?
  createdAt DateTime @default(now())

  users        User[]
  items        Item[]
  buyers       Buyer[]
  sales        Sale[]
  itemTypes    ItemType[]
  models       ItemModel[]
  payments     Payment[]
  metalReceipts MetalReceipt[]
  subscription Subscription?
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(STAFF)
  customRole   String?
  permissions  String[] @default([])
  shopId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Subscription {
  id            String    @id @default(uuid())
  shopId        String    @unique
  status        SubStatus @default(TRIAL)
  trialEndsAt   DateTime  @default(dbgenerated("NOW() + INTERVAL '14 days'"))
  startedAt     DateTime?
  endsAt        DateTime?
  voucherNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Item {
  id           String   @id @default(uuid())
  shopId       String
  barcode      String
  type         String
  model        String?
  stone_weight Float?
  weight       Float
  status       String   @default("In Stock")
  dateAdded    DateTime @default(now())

  shop  Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales Sale[]

  @@unique([barcode, shopId])
}

model Buyer {
  id     String @id @default(uuid())
  shopId String
  name   String

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales    Sale[]
  payments Payment[]
  metalReceipts MetalReceipt[]
}

model Payment {
  id        String   @id @default(uuid())
  shopId    String
  buyerId   String
  amount    Float
  date      DateTime @default(now())
  notes     String?

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  buyer Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)
}

model Sale {
  id      String   @id @default(uuid())
  shopId  String
  itemId          String
  buyerId         String
  date            DateTime @default(now())
  weight          Float
  makingCharge    Float    @default(0)

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id])
  buyer Buyer @relation(fields: [buyerId], references: [id])
}

model ItemType {
  id     String @id @default(uuid())
  shopId String
  name   String
  purity Float  @default(1.0)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([name, shopId])
}

model ItemModel {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  @@unique([name, shopId])
}

model MetalReceipt {
  id        String   @id @default(uuid())
  shopId    String
  buyerId   String
  date      DateTime @default(now())
  weight    Float
  purity    Float    @default(0.995)
  notes     String?

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  buyer Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)
}

