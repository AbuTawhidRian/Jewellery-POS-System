datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum SubStatus {
  TRIAL
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

model Shop {
  id        String   @id @default(uuid())
  name      String
  trn       String?
  address   String?
  email     String?
  phone     String?
  slogan    String?
  logoUrl   String?
  createdAt DateTime @default(now())

  users        User[]
  items        Item[]
  buyers       Buyer[]
  sales        Sale[]
  itemTypes    ItemType[]
  models       ItemModel[]
  payments     Payment[]
  metalReceipts MetalReceipt[]
  subscription Subscription?
  branches     Branch[]
  itemTransfers ItemTransfer[]
}

model Branch {
  id        String   @id @default(uuid())
  shopId    String
  name      String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  items        Item[]
  buyers       Buyer[]
  sales        Sale[]
  payments     Payment[]
  metalReceipts MetalReceipt[]
  
  transfersOut ItemTransfer[] @relation("TransfersOut")
  transfersIn  ItemTransfer[] @relation("TransfersIn")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(STAFF)
  customRole   String?
  shopId       String
  accessibleBranches String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Subscription {
  id            String    @id @default(uuid())
  shopId        String    @unique
  status        SubStatus @default(TRIAL)
  trialEndsAt   DateTime  @default(dbgenerated("NOW() + INTERVAL '14 days'"))
  startedAt     DateTime?
  endsAt        DateTime?
  voucherNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Item {
  id           String   @id @default(uuid())
  shopId       String
  branchId     String?
  barcode      String
  type         String
  model        String?
  stone_weight Float?
  weight       Float
  status       String   @default("In Stock")
  dateAdded    DateTime @default(now())

  shop     Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch   Branch?        @relation(fields: [branchId], references: [id])
  sales    Sale[]
  transfers ItemTransfer[]

  @@unique([barcode, shopId])
}

model ItemTransfer {
  id           String   @id @default(uuid())
  shopId       String
  itemId       String
  fromBranchId String
  toBranchId   String
  status       String   @default("PENDING") // PENDING, RECEIVED, REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  
  shop         Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  item         Item   @relation(fields: [itemId], references: [id])
  fromBranch   Branch @relation("TransfersOut", fields: [fromBranchId], references: [id])
  toBranch     Branch @relation("TransfersIn", fields: [toBranchId], references: [id])
}

model Buyer {
  id       String  @id @default(uuid())
  shopId   String
  branchId String?
  name     String

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  sales         Sale[]
  payments      Payment[]
  metalReceipts MetalReceipt[]
}

model Payment {
  id       String   @id @default(uuid())
  shopId   String
  branchId String?
  buyerId  String
  amount   Float
  date     DateTime @default(now())
  notes    String?

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])
  buyer  Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
}

model Sale {
  id           String   @id @default(uuid())
  shopId       String
  branchId     String?
  itemId       String
  buyerId      String
  date         DateTime @default(now())
  weight       Float
  makingCharge Float    @default(0)

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])
  item   Item    @relation(fields: [itemId], references: [id])
  buyer  Buyer   @relation(fields: [buyerId], references: [id])
}

model ItemType {
  id     String @id @default(uuid())
  shopId String
  name   String
  purity Float  @default(1.0)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([name, shopId])
}

model ItemModel {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  @@unique([name, shopId])
}

model MetalReceipt {
  id       String   @id @default(uuid())
  shopId   String
  branchId String?
  buyerId  String
  date     DateTime @default(now())
  weight   Float
  purity   Float    @default(0.995)
  notes    String?

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])
  buyer  Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
}

